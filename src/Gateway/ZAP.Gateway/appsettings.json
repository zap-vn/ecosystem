{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "app-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/v1/customer/{**catch-all}"
        }
      },
      "app-docs-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/docs/app/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/scalar/{**catch-all}" }
        ]
      },
      "identity-docs-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/docs/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/scalar/{**catch-all}" }
        ]
      },
      "app-json-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/swagger/app-json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      },
      "identity-json-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger/identity-json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      },
      "identity-portal-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity-portal/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "app-portal-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/app-portal/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "crm-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/api/v1/crm/{**catch-all}"
        }
      },
      "sales-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/api/v1/sales/{**catch-all}"
        }
      },
      "finance-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/api/v1/finance/{**catch-all}"
        }
      },
      "hrm-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/api/v1/hrm/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/api/v1/inventory/{**catch-all}"
        }
      },
      "crm-docs-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/docs/crm/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/scalar/{**catch-all}" }
        ]
      },
      "crm-json-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/docs/crm/openapi/v1.json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      },
      "default-openapi-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/openapi/v1.json"
        }
      },
      "crm-portal-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/crm-portal/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "api-fallback-route": {
        "ClusterId": "crm-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5178"
          }
        }
      },
      "app-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5182"
          }
        }
      },
      "crm-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5146"
          }
        }
      }
    }
  }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "app-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/api/v1/customer/{**catch-all}"
        }
      },
      "app-docs-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/docs/app/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/scalar/{**catch-all}" }
        ]
      },
      "identity-docs-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/docs/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/scalar/{**catch-all}" }
        ]
      },
      "app-json-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/swagger/app-json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      },
      "identity-json-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/swagger/identity-json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      },
      "identity-portal-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity-portal/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "app-portal-route": {
        "ClusterId": "app-cluster",
        "Match": {
          "Path": "/app-portal/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7181"
          }
        }
      },
      "app-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7049"
          }
        }
      }
    }
  }
}

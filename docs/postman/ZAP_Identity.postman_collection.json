{
	"info": {
		"_postman_id": "0b14c336-1db7-44a6-993d-4c3ab1b91ef4",
		"name": "ZAP Ecosystem Identity Service",
		"description": "Chứa toàn bộ các endpoints liên quan đến hệ thống quản trị danh tính và đăng nhập cho Microservice Identity của nền tảng phần mềm ZAP ERP/CRM/App.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Features - Auth",
			"item": [
				{
					"name": "App Auth",
					"item": [
						{
							"name": "v1 - Customer Login",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"var jsonData = pm.response.json();",
											"if (jsonData.success && jsonData.data && jsonData.data.access_token) {",
											"    pm.environment.set(\"access_token\", jsonData.data.access_token);",
											"    console.log(\"Saved access_token to environment\");",
											"}"
										],
										"type": "text/javascript"
									}
								}
							],
							"request": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json",
										"type": "text"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"dialing_code\": \"+84\",\n    \"phone_number\": \"388888888\",\n    \"password\": \"Password123!\"\n}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{baseUrl}}/api/v1/auth/customer/login",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"api",
										"v1",
										"auth",
										"customer",
										"login"
									]
								},
								"description": "API xử lý xác thực quyền Customer trên thiết bị Mobile App."
							},
							"response": []
						}
					]
				}
			]
		},
		{
			"name": "Features - Customers",
			"item": [
				{
					"name": "Profile",
					"item": [
						{
							"name": "v1 - Get Customer Profile",
							"request": {
								"method": "GET",
								"header": [
									{
										"key": "Authorization",
										"value": "Bearer {{access_token}}",
										"type": "text"
									}
								],
								"url": {
									"raw": "{{baseUrl}}/api/v1/customer/profile",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"api",
										"v1",
										"customer",
										"profile"
									]
								},
								"description": "API lấy thông tin Profile khách hàng (Hạng, Điểm thưởng). Yêu cầu JWT."
							},
							"response": []
						}
					]
				}
			]
		}
	]
}

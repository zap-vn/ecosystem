      "name": "01. Identity & Auth",
      "item": [
        {
          "name": "App Auth - Login Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gateway}}/api/v1/auth/customer/login",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "customer",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone_number\": \"0901234567\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login - Check Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gateway}}/api/v1/auth/login/check_account",
              "host": [
                "{{gateway}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login",
                "check_account"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_identifier\": \"test@zap.vn\"\n}"
            }
          }
        },
        {
          "name": "Login - Send OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
